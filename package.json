{
  "name": "vantage",
  "version": "1.0.0",
  "private": true,
  "description": "VANTAGE — AI second-screen companion for live football. FIFA for the Other 7 Billion.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'Lint passed (no linter configured yet)'",
    "check": "npm run lint && npm run test && npm run build",
    "backend": "cd backend && ./venv/bin/python3 proxy.py",
    "start": "concurrently \"npm run dev\" \"npm run backend\""
  },
  "dependencies": {
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  },
  "keywords": [
    "football",
    "ai",
    "gemini",
    "accessibility",
    "multilingual",
    "live-sports",
    "second-screen"
  ],
  "author": "VANTAGE Team",
  "license": "MIT"
}
